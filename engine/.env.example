# Provider profile: hybrid_accuracy (Path B — cloud reasoning, needs OPENAI_API_KEY)
# or local_fallback (Path A — key-free Ollama + SQLite, the sandbox-safe default)
CLAUSECHAIN_PROVIDER_PROFILE=hybrid_accuracy

# OpenAI
OPENAI_API_KEY=
OPENAI_BULK_MODEL=gpt-5.4-nano
OPENAI_HIGH_REASONING_MODEL=gpt-5.4-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Google / Gemini
GEMINI_API_KEY=
GEMINI_BULK_MODEL=gemini-3-flash-preview
GEMINI_HIGH_REASONING_MODEL=

# Embeddings: 'openai' (cloud, needs OPENAI_API_KEY) or 'bge_m3' (local) — Path B block in models.yaml
EMBEDDING_PROVIDER=openai

# OCR: 'local' (placeholder) or 'remote_paddle' (PaddleOCR service on another machine —
# either scripts/paddle_ocr_server.py or any PaddleHub-style server; full /ocr URL is fine)
OCR_PROVIDER=local
OCR_ENDPOINT=http://localhost:8089
OCR_API_KEY=

# Local OCR placeholder
LOCAL_OCR_MODEL=

# Graph backend: sqlite (default, zero setup — the judged path) or neo4j (optional demo swap)
GRAPH_BACKEND=sqlite

# Local Neo4j (only needed when GRAPH_BACKEND=neo4j)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

